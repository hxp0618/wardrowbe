# ============================================================================
# Wardrobe 环境变量 / Environment Configuration
# ============================================================================
# 复制本文件为 .env 并按环境修改 / Copy to .env and adjust for your environment
# 生产环境请生成强随机密钥：openssl rand -hex 32
# ============================================================================

# ----------------------------------------------------------------------------
# 数据库 / Database
# ----------------------------------------------------------------------------
# 中文：PostgreSQL 连接与容器内数据库名、端口
POSTGRES_USER=wardrobe
POSTGRES_PASSWORD=change-me-use-secure-password
POSTGRES_DB=wardrobe
POSTGRES_PORT=5432

# 中文：生产环境使用已有 PostgreSQL 时，在 .env 中设置完整连接串（覆盖 docker-compose 默认）
# 需使用 asyncpg 驱动前缀：postgresql+asyncpg://
# 密码含 @ : / 等字符时请 URL 编码
# DATABASE_URL=postgresql+asyncpg://user:password@db.example.com:5432/wardrobe

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
# 中文：Redis 服务端口（缓存、队列等）
REDIS_PORT=6379

# 中文：生产环境使用已有 Redis 时设置（含密码示例 redis://:secret@redis.example.com:6379/0）
# REDIS_URL=redis://redis.example.com:6379/0

# ----------------------------------------------------------------------------
# 后端 / Backend
# ----------------------------------------------------------------------------
# 中文：API 对外端口
BACKEND_PORT=8000
# 中文：会话与 JWT 等签名用密钥，生产环境务必更换
# IMPORTANT: Generate a secure secret for production
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
# 中文：设为 DEBUG=true 可启用开发环境账号密码登录（无需 OIDC）
# 注意：开发登录还要求 SECRET_KEY 与 docker-compose 默认值一致（change-me-in-production）。
# 若你改了 SECRET_KEY，开发环境登录将不会启用。
# Set DEBUG=true to enable dev credential login (no OIDC required)
# NOTE: Dev mode also requires SECRET_KEY=change-me-in-production (the docker-compose default).
# If you override SECRET_KEY, dev login will not activate.
# DEBUG=true

# ----------------------------------------------------------------------------
# 前端 / Frontend
# ----------------------------------------------------------------------------
# 中文：Next.js 开发服务器端口
FRONTEND_PORT=3000
# 中文：NextAuth 回调等使用的站点根 URL（部署时改为实际域名）
NEXTAUTH_URL=http://localhost:3000
# 中文：NextAuth 加密密钥，生产环境务必更换
# IMPORTANT: Generate a secure secret for production
NEXTAUTH_SECRET=change-me-in-production-use-openssl-rand-hex-32

# ----------------------------------------------------------------------------
# 身份认证 / Authentication (OIDC 等)
# ----------------------------------------------------------------------------
# 中文：全部留空则使用开发环境账号密码登录（默认）
# 以下任选一种方式 / Choose ONE of the following authentication methods:

# 选项 1：OIDC 提供商
# Option 1: OIDC
# OIDC_ISSUER_URL=https://auth.example.com
# OIDC_CLIENT_ID=wardrobe
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_END_SESSION_URL=https://auth.example.com/api/oidc/end-session
# 中文：若 OIDC 使用自签名证书，可设为 true（仅当你清楚风险时）
# Set to true if your OIDC provider uses a self-signed certificate:
# OIDC_SKIP_SSL_VERIFY=false

# 选项 2：前置认证（TinyAuth、Authelia 等反向代理信任头）
# Option 2: Forward Auth (TinyAuth, Authelia, etc.)
# AUTH_TRUST_PROXY=true

# ----------------------------------------------------------------------------
# DNS（可选）
# ----------------------------------------------------------------------------
# 中文：若 OIDC 等使用本机 hostname，容器内无法解析时，可填你局域网 DNS 服务器 IP
# If your OIDC provider or other services use a local DNS hostname that
# Docker containers can't resolve, set this to your local DNS server IP:
# LOCAL_DNS=10.0.0.1

# ----------------------------------------------------------------------------
# AI 服务 / AI Service
# ----------------------------------------------------------------------------
# 中文：必须配置一种 AI；应用需要「视觉模型」分析衣物图片 + 「文本模型」做推荐
# REQUIRED: Choose ONE of the following AI providers
# The app needs a vision model (for analyzing clothing images) and a text model (for recommendations)
# ============================================================================

# 选项 1：Ollama（推荐，本地免费，无需 API Key）
# Option 1: Ollama (Recommended - FREE, runs locally, no API key needed)
# ============================================================================
# 1. 从 https://ollama.ai 安装 Ollama
# 2. 拉取模型，例如：
#    ollama pull llava:7b      # 视觉
#    ollama pull gemma3        # 文本（也可用 llama3、qwen2.5、mistral 等）
# 3. Docker 内访问宿主机 Ollama 常用 host.docker.internal
AI_BASE_URL=http://host.docker.internal:11434/v1
AI_API_KEY=not-needed
AI_VISION_MODEL=llava:7b
AI_TEXT_MODEL=gemma3:latest

# 选项 2：OpenAI（付费 API）
# Option 2: OpenAI (Paid API - requires API key)
# ============================================================================
# 取消下面注释并注释掉上方 Ollama 配置
# Uncomment these lines and comment out the Ollama config above:
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-your-api-key-here
# AI_VISION_MODEL=gpt-4o
# AI_TEXT_MODEL=gpt-4o

# 选项 3：LocalAI（自建类 OpenAI 接口）
# Option 3: LocalAI (Self-hosted OpenAI alternative)
# ============================================================================
# AI_BASE_URL=http://localai:8080/v1
# AI_API_KEY=not-needed
# AI_VISION_MODEL=gpt-4-vision-preview
# AI_TEXT_MODEL=gpt-3.5-turbo

# 选项 4：Azure OpenAI
# Option 4: Azure OpenAI
# ============================================================================
# AI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment/
# AI_API_KEY=your-azure-api-key
# AI_VISION_MODEL=gpt-4o
# AI_TEXT_MODEL=gpt-4o

# ----------------------------------------------------------------------------
# 通知渠道（均可选）
# ----------------------------------------------------------------------------
# ntfy.sh 推送
# ntfy.sh push notifications
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=test
NTFY_TOKEN=emKR*oE6MC%F5U

# Mattermost Webhook
MATTERMOST_WEBHOOK_URL=

# Bark（iOS 推送，可选：仅用于前端表单的默认服务器地址；设备密钥在「通知设置」里按用户填写）
# Bark (iOS push). Optional: default API host for the UI; device key is set per user in notification settings.
BARK_SERVER=https://api.day.app

# 邮件通知
# Email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
