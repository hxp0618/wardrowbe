{
  "name": "wardrowbe-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "lint:frontend": "npm --workspace frontend run lint",
    "test:frontend": "npm --workspace frontend run test",
    "lint:miniapp": "npm --workspace wechat-miniapp run lint --if-present",
    "test:miniapp": "npm --workspace wechat-miniapp run test --if-present",
    "build:miniapp": "npm --workspace wechat-miniapp run build --if-present"
  },
  "workspaces": [
    "frontend",
    "wechat-miniapp",
    "packages/*"
  ]
}
