{
  "name": "@wardrowbe/shared-i18n",
  "version": "0.1.0",
  "private": true,
  "description": "Shared next-intl message JSON (en/zh) for Wardrowbe clients",
  "sideEffects": false,
  "exports": {
    "./locale/en.json": "./locale/en.json",
    "./locale/zh.json": "./locale/zh.json",
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "types": "./src/index.ts",
  "files": [
    "locale",
    "src"
  ]
}
